# ==============================================================================
# FRONTEND CONFIG
# ==============================================================================

# API endpoint (change based on deployment)
# Local development: http://localhost:5000
# Production: https://api.yourdomain.com
# NOTE: Frontend now auto-detects API URL from /api/config at runtime
VITE_API_URL=http://localhost:5000

# Application environment
VITE_ENV=development

# ==============================================================================
# SERVER CONFIG
# ==============================================================================

# Server port
PORT=5000

# Environment (development or production)
NODE_ENV=development

# Maximum upload file size (in bytes, default: 100MB)
MAX_FILE_SIZE=104857600

# Request timeout (in milliseconds, default: 5 minutes)
UPLOAD_TIMEOUT=300000

# ==============================================================================
# CORS & SECURITY
# ==============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API rate limit (requests per minute)
RATE_LIMIT=100

# ==============================================================================
# DATABASE (Optional - for future features)
# ==============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/picfin

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================

# AWS S3 Configuration (for cloud storage)
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=picfin-uploads

# SendGrid API Key (for email notifications)
# SENDGRID_API_KEY=your_key

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable detailed logging
DEBUG=false

# ==============================================================================
# NOTES FOR SETUP
# ==============================================================================

# 1. Copy this file to .env in the root directory
#    cp .env.example .env
#
# 2. Fill in your specific values
#
# 3. NEVER commit .env to GitHub
#    (.gitignore already excludes it)
#
# 4. For production, create a separate .env.production
#    The frontend will auto-detect the API URL from /api/config endpoint
#
# 5. Use .env.local for local overrides (not committed)

# ==============================================================================
# DEPLOYMENT FLOW
# ==============================================================================

# Development:
#   1. Frontend runs on http://localhost:5173
#   2. Backend runs on http://localhost:5000
#   3. Frontend calls /api/config to get API URL
#   4. Falls back to VITE_API_URL if /api/config fails

# Production:
#   1. Build frontend: npm run build (API URL embedded as fallback)
#   2. Deploy backend to https://api.yourdomain.com
#   3. Serve frontend from same or different domain
#   4. Frontend calls /api/config on backend to get runtime API URL
#   5. If /api/config fails (cross-origin), uses fallback URL
